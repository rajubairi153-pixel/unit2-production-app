// ─── REPORT ───────────────────────────────────────────────
function renderReport() {
  if (!summaryData.length) { loadDashboard().then(()=>renderReport()); return; }
  const secs = summaryData.map(d=>d.section);
  const allPct = summaryData.map(d=>Math.round(d.tillDateAchieved/d.tillDateTarget*100));
  const avg = Math.round(allPct.reduce((a,b)=>a+b,0)/allPct.length);
  const totA = summaryData.reduce((a,d)=>a+d.tillDateAchieved,0);
  const totT = summaryData.reduce((a,d)=>a+d.tillDateTarget,0);

  document.getElementById('rep-kpis').innerHTML = `
    <div class="stat-card" style="border-top:3px solid var(--accent)">
      <div class="card-label">Avg Achievement</div><div class="card-value" style="color:var(--accent)">${avg}%</div><div class="card-sub">All sections</div>
    </div>
    <div class="stat-card" style="border-top:3px solid var(--green)">
      <div class="card-label">Total Achieved</div><div class="card-value" style="color:var(--green)">${totA.toLocaleString()}</div><div class="card-sub">Combined</div>
    </div>
    <div class="stat-card" style="border-top:3px solid var(--red)">
      <div class="card-label">Total Gap</div><div class="card-value" style="color:var(--red)">${(totT-totA).toLocaleString()}</div><div class="card-sub">Below target</div>
    </div>`;

  document.getElementById('rep-tbody').innerHTML = summaryData.map(d=>{
    const pct=Math.round(d.tillDateAchieved/d.tillDateTarget*100);
    const gap=d.tillDateTarget-d.tillDateAchieved;
    const eff=Math.round(d.tillDateAchieved/d.capacity*100);
    const cls=pct>=90?'pct-green':pct>=80?'pct-yellow':'pct-red';
    return `<tr>
      <td><b style="color:${SEC_COLORS[d.section]}">${d.section}</b></td>
      <td>${d.capacity.toLocaleString()}</td><td>${d.monthTarget.toLocaleString()}</td>
      <td>${d.tillDateTarget.toLocaleString()}</td><td><b>${d.tillDateAchieved.toLocaleString()}</b></td>
      <td><span class="pct-cell ${cls}">${pct}%</span></td>
      <td style="color:var(--red)">${gap>0?'-'+gap.toLocaleString():'✅ Ahead'}</td>
      <td>${eff}%</td>
    </tr>`;
  }).join('');

  dc('c-gap');
  charts['gap']=new Chart(document.getElementById('c-gap'),{type:'bar',data:{labels:secs,datasets:[
    {label:'Achieved',data:summaryData.map(d=>d.tillDateAchieved),backgroundColor:secs.map(s=>SEC_COLORS[s]+'cc'),borderRadius:4},
    {label:'Gap',data:summaryData.map(d=>Math.max(0,d.tillDateTarget-d.tillDateAchieved)),backgroundColor:'rgba(239,68,68,0.4)',borderRadius:4}
  ]},options:{...copts(),scales:{x:{stacked:true,...copts().scales.x},y:{stacked:true,...copts().scales.y}}}});

  dc('c-radar');
  charts['radar']=new Chart(document.getElementById('c-radar'),{type:'radar',data:{labels:secs,datasets:[{
    label:'Efficiency %',
    data:summaryData.map(d=>Math.round(d.tillDateAchieved/d.capacity*100)),
    backgroundColor:'rgba(0,212,255,0.1)',borderColor:'#00d4ff',pointBackgroundColor:'#00d4ff'
  }]},options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{labels:{color:'#94a3b8',font:{size:11}}}},
    scales:{r:{ticks:{color:'#64748b',backdropColor:'transparent'},grid:{color:'rgba(255,255,255,0.06)'},pointLabels:{color:'#94a3b8',font:{size:11}}}}}
  });
}

