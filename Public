async function submitEntry() {
  const date = document.getElementById('e-date').value;
  const section = document.getElementById('e-section').value;
  const plan = +document.getElementById('e-plan').value;
  const actual = +document.getElementById('e-actual').value;
  const shift = document.getElementById('e-shift').value;
  const remarks = document.getElementById('e-remarks').value;
  if (!date||!plan||!actual) { showToast('Please fill all required fields.','error'); return; }
  
  const btn = document.getElementById('btn-save');
  btn.disabled=true; btn.textContent='Saving…';
  try {
    if (token==='demo') {
      await new Promise(r=>setTimeout(r,600)); // simulate
      showToast('✅ [Demo] Entry saved: '+section+' — '+actual+' units','success');
    } else {
      await api('/api/entries',{method:'POST',body:JSON.stringify({date,section,plan,actual,shift,remarks})});
      showToast('✅ Saved to MongoDB! '+section+' — '+actual+' units','success');
      loadDashboard();
    }
  } catch(e) { showToast('❌ Error: '+e.message,'error'); }
  btn.disabled=false; btn.textContent='✅ Save to MongoDB';
}

