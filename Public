    {label:'% Achieved',data:summaryData.map(d=>Math.round(d.tillDateAchieved/d.tillDateTarget*100)),backgroundColor:cols.map(c=>c+'cc'),borderRadius:6}
  ]},options:{...copts(),scales:{...copts().scales,y:{...copts().scales.y,max:110}}}});

  dc('c-daily');
