// ─── AUTH ─────────────────────────────────────────────────
async function doLogin() {
  const username = document.getElementById('l-user').value.trim();
  const password = document.getElementById('l-pass').value;
  const btn = document.getElementById('btn-login');
  const err = document.getElementById('auth-error');
  if (!username || !password) { err.textContent = 'Enter username and password.'; return; }
  btn.disabled = true; btn.textContent = 'Logging in…';
  try {
    const r = await fetch(API_BASE + '/api/login', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ username, password })
    });
    const d = await r.json();
    if (!r.ok) { err.textContent = '❌ ' + (d.error || 'Login failed'); btn.disabled=false; btn.textContent='LOGIN →'; return; }
    token = d.token;
    currentUser = d.user;
    localStorage.setItem('unit2_token', token);
    localStorage.setItem('unit2_user', JSON.stringify(currentUser));
    err.textContent = '';
    document.getElementById('auth-screen').style.display = 'none';
    document.getElementById('app').style.display = 'flex';
    setupUI();
    loadDashboard();
  } catch (e) {
    // Fallback demo mode if server offline
    err.textContent = '⚠ Server offline — using demo mode';
    const DEMO = {
      admin:{name:'Super Admin',username:'admin',pass:'admin123',role:'admin',sections:['Container','Lid','Assembly','Charging','Packing','Dispatch'],color:'#f59e0b'},
      user1:{name:'Ravi Kumar',username:'user1',pass:'user123',role:'user',sections:['Container','Lid'],color:'#00d4ff'},
      user2:{name:'Suresh Babu',username:'user2',pass:'user123',role:'user',sections:['Assembly'],color:'#a855f7'},
      user3:{name:'Priya Devi',username:'user3',pass:'user123',role:'user',sections:['Charging'],color:'#ec4899'},
      user4:{name:'Mohan Rao',username:'user4',pass:'user123',role:'user',sections:['Packing'],color:'#22c55e'},
      user5:{name:'Anita Singh',username:'user5',pass:'user123',role:'user',sections:['Dispatch'],color:'#f97316'},
    };
    const u = DEMO[username];
    if (!u || password !== u.pass) { err.textContent = '❌ Invalid credentials'; btn.disabled=false; btn.textContent='LOGIN →'; return; }
    token = 'demo'; currentUser = u;
    localStorage.setItem('unit2_token', token);
    localStorage.setItem('unit2_user', JSON.stringify(currentUser));
    err.textContent = '';
    document.getElementById('auth-screen').style.display = 'none';
    document.getElementById('app').style.display = 'flex';
    setupUI(); loadDashboard();
  }
  btn.disabled=false; btn.textContent='LOGIN →';
}

function doLogout() {
  token = null; currentUser = null;
  localStorage.removeItem('unit2_token');
  localStorage.removeItem('unit2_user');
  document.getElementById('auth-screen').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
  Object.values(charts).forEach(c=>c&&c.destroy&&c.destroy()); charts={};
}

function setupUI() {
  const u = currentUser;
  document.getElementById('nav-av').textContent = u.name[0];
  document.getElementById('nav-av').style.background = u.color || '#0066ff';
  document.getElementById('nav-name').textContent = u.name;
  const rt = document.getElementById('nav-role');
  rt.textContent = u.role==='admin' ? 'ADMIN' : (u.sections||[''])[0].toUpperCase();
  rt.className = 'role-tag ' + (u.role==='admin'?'role-admin':'role-user');
  document.getElementById('admin-nav').style.display = u.role==='admin' ? 'block' : 'none';
}

// ─── NAVIGATION ───────────────────────────────────────────
function showView(name) {
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  const ni = document.getElementById('ni-'+name);
  if (ni) ni.classList.add('active');
  if (name==='entry') renderEntryForm();
  if (name==='history') loadHistory();
  if (name==='report') renderReport();
  if (name==='settings') loadSettings();
}

// ─── API HELPER ───────────────────────────────────────────
async function api(path, opts={}) {
  const headers = {'Content-Type':'application/json', 'Authorization':'Bearer '+token};
  const r = await fetch(API_BASE + path, {...opts, headers});
  if (!r.ok) throw new Error((await r.json()).error || r.statusText);
  return r.json();
}

