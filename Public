  const dailyActual=[0,600,300,0,0,600,200,0,200,100,360,0,375,250,0,0,0,0,0,300,350,400,420,450,480,550];
  charts['daily'] = new Chart(document.getElementById('c-daily'),{type:'line',data:{labels:days,datasets:[
    {label:'Plan',data:Array(26).fill(600),borderColor:'#64748b',borderDash:[5,5],fill:false,pointRadius:0},
    {label:'Actual',data:dailyActual,borderColor:'#00d4ff',backgroundColor:'rgba(0,212,255,0.1)',fill:true,tension:0.3,pointRadius:2}
  ]},options:copts()});

  dc('c-util');
  charts['util'] = new Chart(document.getElementById('c-util'),{type:'bar',data:{labels:secs,datasets:[
    {label:'Capacity',data:summaryData.map(d=>d.capacity),backgroundColor:'rgba(100,116,139,0.3)',borderRadius:4},
    {label:'Month Target',data:summaryData.map(d=>d.monthTarget),backgroundColor:cols.map(c=>c+'99'),borderRadius:4}
  ]},options:copts()});
