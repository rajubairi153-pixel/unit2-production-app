function renderCards() {
  const grid = document.getElementById('cards-grid');
  grid.innerHTML = summaryData.map(d => {
    const pct = Math.round(d.tillDateAchieved/d.tillDateTarget*100);
    const cls = pct>=90?'badge-yellow':pct>=75?'badge-yellow':'badge-red';
    const c = SEC_COLORS[d.section];
    return `<div class="stat-card" style="border-top:3px solid ${c}">
      <div class="card-label">${d.section}</div>
      <div class="card-value" style="color:${c}">${pct}%</div>
      <div class="card-sub">Achieved: ${d.tillDateAchieved.toLocaleString()}</div>
      <div class="card-sub">Target: ${d.tillDateTarget.toLocaleString()}</div>
      <div class="card-badge ${cls}">${pct}%</div>
    </div>`;
  }).join('');
}

function renderSummaryTable() {
  document.getElementById('sum-tbody').innerHTML = summaryData.map(d => {
    const pct = Math.round(d.tillDateAchieved/d.tillDateTarget*100);
    const gap = d.tillDateTarget - d.tillDateAchieved;
    const cls = pct>=90?'pct-yellow':pct>=75?'pct-yellow':'pct-red';
    const icon = pct>=90?'🟡':pct>=75?'🟠':'🔴';
    const status = pct>=90?'On Track':pct>=75?'Below Target':'Critical';
    return `<tr>
      <td><b style="color:${SEC_COLORS[d.section]}">${d.section}</b></td>
      <td>${d.capacity.toLocaleString()}</td>
      <td>${d.monthTarget.toLocaleString()}</td>
